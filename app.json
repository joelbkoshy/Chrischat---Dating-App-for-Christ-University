{
  "expo": {
    "name": "ChrisChat",
    "slug": "chrischat",
    "version": "1.0.0",
    "scheme": "chrischat",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chrischat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ChrisChat needs camera access to take photos and videos.",
        "NSPhotoLibraryUsageDescription": "ChrisChat needs photo library access to upload pictures.",
        "NSMicrophoneUsageDescription": "ChrisChat needs microphone access to record videos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F3EEFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.chrischat.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F3EEFF"
        }
      ],
      "expo-font",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "ChrisChat needs access to your photos to upload profile pictures and share media.",
          "cameraPermission": "ChrisChat needs access to your camera to take photos and videos."
        }
      ],
      "@config-plugins/react-native-webrtc"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04d65b01-9bca-4e63-854e-f32ce9735a71"
      }
    }
  }
}
